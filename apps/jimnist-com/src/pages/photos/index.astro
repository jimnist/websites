---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { galleries } from '../../data/galleries';
---

<BaseLayout title="crazy 8 photos">
  <div class="photos-container">
    <div class="header">
      <img src="/photos/photos.jpg" alt="photos" />
    </div>

    <table class="gallery-list">
      {galleries.map(gallery => (
        <tr>
          <td class="date">{gallery.date}</td>
          <td class="title">
            <a href={`/photos/${gallery.id}/`}>{gallery.title}</a>
          </td>
          <td class="description">{gallery.description}</td>
        </tr>
      ))}
    </table>

    <div class="footer">
      full resolution versions and prints can be had for the asking.
    </div>
  </div>
</BaseLayout>

<style>
  :global(body) {
    background-color: #D8D8D8;
  }

  .photos-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 20px;
  }

  .header {
    background: #FFFF80;
    border: 1px solid #000;
    padding: 10px;
    text-align: center;
    margin-bottom: 10px;
  }

  .header img {
    max-width: 100%;
  }

  .gallery-list {
    width: 100%;
    border: 1px solid #000;
    border-collapse: collapse;
  }

  .gallery-list td {
    padding: 8px;
    border: 1px solid #000;
    vertical-align: top;
  }

  .date {
    width: 80px;
  }

  .title {
    width: 200px;
  }

  .title a {
    color: #000;
  }

  .description {
    color: #666;
  }

  .footer {
    background: #FFFF80;
    border: 1px solid #000;
    padding: 10px;
    text-align: center;
    margin-top: 10px;
    font-size: 12px;
  }
</style>
