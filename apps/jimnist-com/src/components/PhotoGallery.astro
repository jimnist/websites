---
import type { GalleryImage } from '../data/galleries';

interface Props {
  galleryId: string;
  images: GalleryImage[];
}

const { galleryId, images } = Astro.props;
---

<div class="gallery-container">
  <div class="nav-bar">
    <button id="prev-btn" class="nav-btn">&larr; prev</button>
    <a href="/photos/" class="nav-link">photos index</a>
    <button id="next-btn" class="nav-btn">next &rarr;</button>
  </div>

  <div class="image-container">
    <img id="gallery-image" src="" alt="" />
  </div>

  <div class="info-bar">
    <span id="caption"></span>
    <span id="counter"></span>
    <span id="filename" class="filename"></span>
  </div>
</div>

<script define:vars={{ galleryId, images }}>
  let currentIndex = 0;

  const imgEl = document.getElementById('gallery-image');
  const captionEl = document.getElementById('caption');
  const counterEl = document.getElementById('counter');
  const filenameEl = document.getElementById('filename');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  function preloadImage(index) {
    if (index >= 0 && index < images.length) {
      const img = new Image();
      img.src = `/photos/${galleryId}/${images[index].filename}`;
    }
  }

  function showImage(index) {
    if (index < 0) index = images.length - 1;
    if (index >= images.length) index = 0;
    currentIndex = index;

    const image = images[currentIndex];
    imgEl.src = `/photos/${galleryId}/${image.filename}`;
    imgEl.alt = image.caption || image.filename;
    captionEl.textContent = image.caption || '';
    counterEl.textContent = `${currentIndex + 1} of ${images.length}`;
    filenameEl.textContent = image.filename;

    // Preload adjacent images
    preloadImage(currentIndex + 1);
    preloadImage(currentIndex - 1);
  }

  function prevImage() {
    showImage(currentIndex - 1);
  }

  function nextImage() {
    showImage(currentIndex + 1);
  }

  prevBtn.addEventListener('click', prevImage);
  nextBtn.addEventListener('click', nextImage);

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') prevImage();
    if (e.key === 'ArrowRight') nextImage();
  });

  // Click on image to go next
  imgEl.addEventListener('click', nextImage);

  // Initialize
  showImage(0);
</script>

<style>
  .gallery-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 10px;
  }

  .nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #FFFF80;
    border: 1px solid #000;
    padding: 10px;
    margin-bottom: 10px;
  }

  .nav-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    padding: 5px 10px;
  }

  .nav-btn:hover {
    text-decoration: underline;
  }

  .nav-link {
    color: #000;
    text-decoration: none;
  }

  .nav-link:hover {
    text-decoration: underline;
  }

  .image-container {
    background: #000;
    border: 1px solid #000;
    padding: 10px;
    text-align: center;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #gallery-image {
    max-width: 100%;
    max-height: 500px;
    border: 2px solid #fff;
    cursor: pointer;
  }

  .info-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #FFFF80;
    border: 1px solid #000;
    padding: 10px;
    margin-top: 10px;
    font-size: 12px;
  }

  #caption {
    flex: 1;
  }

  #counter {
    width: 60px;
    text-align: center;
  }

  .filename {
    color: #808080;
    width: 150px;
    text-align: right;
  }
</style>
