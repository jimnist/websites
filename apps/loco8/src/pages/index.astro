---
import MiniSmiley from '../components/MiniSmiley.astro';

const positions = [
  { id: 's1', row: 1, col: 1, bg: '/bg/cell-1-1.svg' },
  { id: 's2', row: 1, col: 2, bg: '/bg/cell-1-2.svg' },
  { id: 's3', row: 1, col: 3, bg: '/bg/cell-1-3.svg' },
  { id: 's4', row: 2, col: 1, bg: '/bg/cell-2-1.svg' },
  // center is empty
  { id: 's6', row: 2, col: 3, bg: '/bg/cell-2-3.svg' },
  { id: 's7', row: 3, col: 1, bg: '/bg/cell-3-1.svg' },
  { id: 's8', row: 3, col: 2, bg: '/bg/cell-3-2.svg' },
  { id: 's9', row: 3, col: 3, bg: '/bg/cell-3-3.svg' },
];

const centerBg = '/bg/cell-2-2.svg';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>loco8</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
</head>
<body>
  <div class="grid-container">
    {positions.map(pos => (
      <div class="grid-cell" style={`grid-row: ${pos.row}; grid-column: ${pos.col}; background-image: url(${pos.bg}); background-size: cover;`}>
        <MiniSmiley id={pos.id} />
      </div>
    ))}
    <div class="grid-cell center" style={`grid-row: 2; grid-column: 2; background-image: url(${centerBg}); background-size: cover;`}>
      <div class="logo">
        <div class="logo-line">lo</div>
        <div class="logo-line">co</div>
      </div>
    </div>
  </div>

  <script>
    const PIXEL_SIZE = 20;
    const EYE_SIZE = PIXEL_SIZE * 3;
    const PUPIL_SIZE = PIXEL_SIZE * 1.5;
    const PUPIL_BASE = PIXEL_SIZE * 0.75;
    const MAX_OFFSET = PIXEL_SIZE * 0.75;

    function updateAllPupils(mouseX: number, mouseY: number) {
      const smileys = document.querySelectorAll('.smiley-svg');

      smileys.forEach(svg => {
        const svgRect = svg.getBoundingClientRect();
        const scale = svgRect.width / 380;
        const smileyId = svg.getAttribute('data-smiley-id');

        ['left', 'right'].forEach(side => {
          const eye = svg.querySelector(`[data-eye-id="${smileyId}-${side}"]`);
          const pupil = svg.querySelector(`[data-pupil-id="${smileyId}-${side}"]`);
          if (!eye || !pupil) return;

          const eyeTransform = eye.getAttribute('transform');
          const match = eyeTransform?.match(/translate\((\d+),\s*(\d+)\)/);
          if (!match) return;

          const eyeX = parseInt(match[1]);
          const eyeY = parseInt(match[2]);

          const eyeCenterX = svgRect.left + (eyeX + EYE_SIZE / 2) * scale;
          const eyeCenterY = svgRect.top + (eyeY + EYE_SIZE / 2) * scale;

          const dx = mouseX - eyeCenterX;
          const dy = mouseY - eyeCenterY;
          const distance = Math.sqrt(dx * dx + dy * dy);

          let offsetX = 0;
          let offsetY = 0;
          if (distance > 0) {
            const scaledOffset = Math.min(MAX_OFFSET, distance / scale);
            offsetX = (dx / distance) * scaledOffset;
            offsetY = (dy / distance) * scaledOffset;
          }

          const pupilX = PUPIL_BASE + offsetX;
          const pupilY = PUPIL_BASE + offsetY;
          pupil.setAttribute('x', pupilX.toString());
          pupil.setAttribute('y', pupilY.toString());
        });
      });
    }

    document.addEventListener('mousemove', (e) => {
      updateAllPupils(e.clientX, e.clientY);
    });
  </script>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      background-color: #fffcf0;
      background-image: url('/bg/page.svg');
      background-size: 380px 380px;
    }

    .grid-container {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 1fr);
      gap: 0;
      width: 100vmin;
      max-width: 600px;
      margin: 40px auto 0;
    }

    .grid-cell {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 12px;
    }

    .grid-cell.center {
      /* Center cell with logo */
    }

    .logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: 'Press Start 2P', cursive;
      color: #800020;
      text-transform: uppercase;
      gap: 1vmin;
      width: 100%;
      height: 100%;
    }

    .logo-line {
      font-size: 8vmin;
      line-height: 1;
    }
  </style>
</body>
</html>
